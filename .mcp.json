{
  "name": "database-universal-mcp",
  "description": "MCP server for database universal. Features query sql, list tables, describe table. From MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "query_sql",
      "description": "Execute a SQL query against a database. Supports SQLite, PostgreSQL, and MySQL.",
      "parameters": {
        "type": "object",
        "properties": {
          "connection_string": {
            "type": "string"
          },
          "sql": {
            "type": "string"
          },
          "allow_write": {
            "type": "boolean"
          }
        },
        "required": [
          "connection_string",
          "sql"
        ]
      }
    },
    {
      "name": "list_tables",
      "description": "List all tables in a database.",
      "parameters": {
        "type": "object",
        "properties": {
          "connection_string": {
            "type": "string"
          }
        },
        "required": [
          "connection_string"
        ]
      }
    },
    {
      "name": "describe_table",
      "description": "Describe a table's schema: column names, types, nullability, defaults,",
      "parameters": {
        "type": "object",
        "properties": {
          "connection_string": {
            "type": "string"
          },
          "table_name": {
            "type": "string"
          }
        },
        "required": [
          "connection_string",
          "table_name"
        ]
      }
    },
    {
      "name": "insert_row",
      "description": "Insert a single row into a table. Column names and values are passed",
      "parameters": {
        "type": "object",
        "properties": {
          "connection_string": {
            "type": "string"
          },
          "table_name": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "connection_string",
          "table_name",
          "data"
        ]
      }
    },
    {
      "name": "export_to_csv",
      "description": "Execute a SELECT query and export results to a CSV file.",
      "parameters": {
        "type": "object",
        "properties": {
          "connection_string": {
            "type": "string"
          },
          "sql": {
            "type": "string"
          },
          "output_path": {
            "type": "string"
          }
        },
        "required": [
          "connection_string",
          "sql"
        ]
      }
    }
  ]
}